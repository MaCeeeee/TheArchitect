{
  "name": "thearchitect",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "description": "TheArchitect - Enterprise Architecture Management Platform with 3D Visualization",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",

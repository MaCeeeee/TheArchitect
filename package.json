    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "pdf-parse": "^1.1.1"
  }
}

{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@thearchitect/shared": ["../shared/dist"],
      "@thearchitect/shared/src/*": ["../shared/dist/*"]
    }
  },
  "include": ["src/**/*"]
}

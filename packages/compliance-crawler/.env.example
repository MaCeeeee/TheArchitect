# ─── Compliance Crawler Configuration ────────────────────────────────
# Copy to .env in production and fill real values.
# In Coolify: set these via the UI Environment Variables tab.

# HTTP server
PORT=3100
HOST=0.0.0.0
LOG_LEVEL=info

# MongoDB on Server A (via Tailscale)
MONGODB_URI=mongodb://thearchitect:CHANGE_ME@100.96.198.73:27017/thearchitect?authSource=admin

# Embedding sidecar (Server B local — UC-SIM-001 stack)
EMBEDDING_SERVICE_URL=http://embedding:8001

# Qdrant (Server B local)
QDRANT_URL=http://qdrant-xrldeazh9iqxuccacpehqj9e:6333
QDRANT_API_KEY=

# Crawler behaviour
CRAWLER_USER_AGENT=TheArchitect-Compliance-Crawler/1.0
CRAWLER_REQUEST_DELAY_MS=200

# Firecrawl — for JS/WAF-protected sources (EUR-Lex NIS2 + DSGVO).
# Cloud: get key from firecrawl.dev (free tier 500 pages/month).
# Self-hosted: leave FIRECRAWL_API_URL=http://firecrawl:3002 and key can be any string.
# If empty, nis2/dsgvo fall back to direct cheerio (will fail against live EUR-Lex due to WAF).
FIRECRAWL_API_KEY=
FIRECRAWL_API_URL=

# Server
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# JWT
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-this-to-another-secure-random-string
JWT_REFRESH_EXPIRES_IN=30d

# MongoDB
MONGODB_URI=mongodb://your_user:your_password@localhost:27017/thearchitect?authSource=admin

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-me

# MinIO / S3
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=your_access_key
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=thearchitect-files

# OAuth — Google (https://console.cloud.google.com → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/oauth/google/callback

# OAuth — GitHub (https://github.com/settings/developers → OAuth Apps)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/oauth/github/callback

# OAuth — Microsoft Entra ID (https://portal.azure.com → App registrations)
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_TENANT_ID=common
ENTRA_CALLBACK_URL=http://localhost:4000/api/auth/oauth/microsoft/callback

# AI Copilot — set at least one key to enable
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=  # Optional: for Azure OpenAI or compatible APIs
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# SMTP (password reset emails — leave empty in dev, reset links print to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=TheArchitect <noreply@thearchitect.site>

# Sentry Error Tracking (optional — leave empty to disable)
SENTRY_DSN=
VITE_SENTRY_DSN=

# Connector Credential Encryption (32 bytes = 64 hex chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_ENCRYPTION_KEY=

# Hostinger API
HOSTINGER_API_KEY=

# Data-Server (n8n RAG, private via Tailscale)
# DATA_SERVER_URL: public HTTPS URL or Tailscale internal URL of n8n
# DATA_SERVER_SHARED_SECRET: 32 bytes hex, MUST match X-API-Key check inside n8n webhooks
# Generate with: openssl rand -hex 32
DATA_SERVER_URL=
DATA_SERVER_SHARED_SECRET=

# Umami web analytics (self-hosted, privacy-friendly)
# UMAMI_DB_PASSWORD: Postgres password for the umami DB user
# UMAMI_APP_SECRET:  random secret for session/JWT signing inside Umami
# Generate each with: openssl rand -hex 32
UMAMI_DB_PASSWORD=
UMAMI_APP_SECRET=

# Regulation corpus crawl scheduler (THE-362) — keeps the corpus fresh via the
# Server B crawler. All optional; sensible defaults baked in.
# COMPLIANCE_CRAWLER_URL: Server B crawler base URL (default http://100.106.223.83:3100)
# REGULATION_CRAWL_ENABLED: "false" to disable the scheduler entirely (default on)
# REGULATION_CRAWL_SOURCES: comma list (default "nis2,lksg,dsgvo")
# REGULATION_CRAWL_INTERVAL_MINUTES: default 10080 (weekly)
COMPLIANCE_CRAWLER_URL=
# Optional shared secret sent as X-Crawler-Token to the crawler's write endpoints
# (defense-in-depth). Must match CRAWLER_SHARED_SECRET on the crawler side.
COMPLIANCE_CRAWLER_SECRET=
REGULATION_CRAWL_ENABLED=
REGULATION_CRAWL_SOURCES=
REGULATION_CRAWL_INTERVAL_MINUTES=

# Canonical regulation corpus (THE-368) — dedicated Mongo on Server B, reached from
# Server A via Tailnet. Read-path + seed-migration + drift-detection use a SEPARATE
# connection (ADR-0002). Leave empty until the corpus is exposed to Server A.
# mongodb://<user>:<pw>@<corpus-tailnet-ip>:27017/regulations-corpus?authSource=admin
CORPUS_MONGODB_URI=

# UC-LAW-002 (THE-459) — korpusweite Regulierungs-Discovery aus dem Architektur-Modell.
# Feature bleibt dunkel bis LAW_DISCOVERY_ENABLED=true UND Sidecar/Qdrant erreichbar sind.
LAW_DISCOVERY_ENABLED=false
# Top-K Paragraphen aus dem Korpus je Discovery-Lauf (Default 60, Tuning-Hook fürs Eval-Gate .6).
LAW_DISCOVERY_TOP_K=
# Slice-2 LLM-Judge (THE-462) — braucht ANTHROPIC_API_KEY; ohne Key degradiert
# /discover sauber auf den deterministischen Stage-A-Report.
# Judge-Modell (Default claude-haiku-4-5-20251001; auf Sonnet hochstufen wenn Eval-Gate .6 es verlangt).
LAW_DISCOVERY_JUDGE_MODEL=
# Nur Kandidaten mit Retrieval-Score >= Schwelle werden gejudged (Default 0.3; 0 = alle).
LAW_DISCOVERY_JUDGE_THRESHOLD=
# Max. Kandidaten pro Lauf, die den (kostenpflichtigen) Judge sehen (Default 5; 0 = Judge-Kill-Switch).
LAW_DISCOVERY_MAX_JUDGE=
# Embedding-Sidecar + Qdrant für den governten Korpus-Vektor-Search (geteilt mit UC-SIM-001,
# elementSimilarity.service.ts). Ohne diese degradiert LAW-002 sauber auf leere Kandidatenliste.
EMBEDDING_SIDECAR_URL=
QDRANT_URL=
QDRANT_API_KEY=

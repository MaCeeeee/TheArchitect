# Server
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# JWT
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-this-to-another-secure-random-string
JWT_REFRESH_EXPIRES_IN=30d

# MongoDB
MONGODB_URI=mongodb://thearchitect:thearchitect_dev_2024@localhost:27017/thearchitect?authSource=admin

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=thearchitect_dev_2024

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=thearchitect_dev_2024

# MinIO / S3
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=thearchitect
MINIO_SECRET_KEY=thearchitect_dev_2024
MINIO_BUCKET=thearchitect-files

# OAuth — Google (https://console.cloud.google.com → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/oauth/google/callback

# OAuth — GitHub (https://github.com/settings/developers → OAuth Apps)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/oauth/github/callback

# OAuth — Microsoft Entra ID (https://portal.azure.com → App registrations)
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_TENANT_ID=common
ENTRA_CALLBACK_URL=http://localhost:4000/api/auth/oauth/microsoft/callback

# AI Copilot — set at least one key to enable
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=  # Optional: for Azure OpenAI or compatible APIs
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

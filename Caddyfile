thearchitect.site, www.thearchitect.site {
	reverse_proxy app:4000

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
	}
}

# Self-hosted Umami web analytics (privacy-friendly, cookie-free).
# Requires DNS A-record: analytics.thearchitect.site -> 76.13.150.49
# Caddy provisions the Let's Encrypt cert automatically once DNS resolves.
analytics.thearchitect.site {
	reverse_proxy umami:3000
}
